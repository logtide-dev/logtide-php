{
  "name": "logtide/logtide-laravel",
  "description": "Laravel integration for the LogTide PHP SDK",
  "type": "library",
  "keywords": [
    "logtide",
    "laravel",
    "logging",
    "observability",
    "tracing"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Polliog",
      "email": "giuseppe@solture.it"
    }
  ],
  "require": {
    "php": "^8.1",
    "logtide/logtide": "^0.7",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0",
    "illuminate/http": "^10.0 || ^11.0 || ^12.0",
    "illuminate/routing": "^10.0 || ^11.0 || ^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "LogTide\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LogTide\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "LogTide\\Laravel\\LogtideServiceProvider"
      ],
      "aliases": {
        "Logtide": "LogTide\\Laravel\\LogtideFacade"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
