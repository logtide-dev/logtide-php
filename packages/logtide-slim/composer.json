{
  "name": "logtide/logtide-slim",
  "description": "LogTide integration for Slim Framework 4",
  "type": "library",
  "keywords": [
    "logtide",
    "slim",
    "middleware",
    "logging",
    "observability"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Polliog",
      "email": "giuseppe@solture.it"
    }
  ],
  "require": {
    "php": "^8.1",
    "logtide/logtide": "^0.1",
    "slim/slim": "^4.0",
    "psr/http-server-middleware": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "LogTide\\Slim\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LogTide\\Slim\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
