{
  "name": "logtide/logtide-symfony",
  "description": "Symfony integration for LogTide PHP SDK - automatic request tracing, console command monitoring, and Doctrine query tracking",
  "type": "symfony-bundle",
  "keywords": [
    "logtide",
    "symfony",
    "logging",
    "observability",
    "tracing",
    "monitoring"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Polliog",
      "email": "giuseppe@solture.it"
    }
  ],
  "require": {
    "php": "^8.1",
    "logtide/logtide": "^0.1",
    "symfony/http-kernel": "^6.4 || ^7.0",
    "symfony/dependency-injection": "^6.4 || ^7.0",
    "symfony/config": "^6.4 || ^7.0",
    "symfony/event-dispatcher": "^6.4 || ^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "symfony/console": "^6.4 || ^7.0",
    "doctrine/dbal": "^3.8 || ^4.0"
  },
  "suggest": {
    "symfony/console": "Required for console command tracing (^6.4 || ^7.0)",
    "doctrine/dbal": "Required for Doctrine query breadcrumbs (^3.8 || ^4.0)"
  },
  "autoload": {
    "psr-4": {
      "LogTide\\Symfony\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LogTide\\Symfony\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
