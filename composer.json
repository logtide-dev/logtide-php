{
  "name": "logward-dev/sdk-php",
  "description": "Official PHP SDK for LogWard - Self-hosted log management with batching, retry logic, circuit breaker, query API, and middleware support",
  "type": "library",
  "keywords": [
    "logward",
    "logging",
    "logs",
    "log-management",
    "monitoring",
    "observability",
    "self-hosted",
    "tracing",
    "circuit-breaker",
    "laravel",
    "symfony"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Polliog",
      "email": "giuseppe@solture.it"
    }
  ],
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.8",
    "ramsey/uuid": "^4.7",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.8"
  },
  "autoload": {
    "psr-4": {
      "LogWard\\SDK\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LogWard\\SDK\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html coverage",
    "phpstan": "phpstan analyse src tests --level=8",
    "cs": "phpcs --standard=PSR12 src tests",
    "cs:fix": "phpcbf --standard=PSR12 src tests"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}